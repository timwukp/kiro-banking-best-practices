{
  "name": "kiro-banking-cdk",
  "version": "2.0.0",
  "description": "AWS CDK infrastructure for MAS-compliant Kiro banking environments",
  "bin": {
    "kiro-banking": "bin/kiro-banking.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy": "cdk deploy --all",
    "diff": "cdk diff",
    "lint": "eslint . --ext .ts",
    "nag": "cdk synth 2>&1 | grep -E '(AwsSolutions|Warning|Error)'"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "aws-cdk": "^2.254.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "~5.7.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.254.0",
    "cdk-nag": "^2.38.0",
    "constructs": "^10.5.1"
  }
}
